{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/api/*", "/*.{css,js,ico,svg,png,jpg,jpeg,gif,webp,woff,woff2,ttf,otf}"]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  }
}
